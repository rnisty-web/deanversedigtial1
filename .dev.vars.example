# Copy to .dev.vars for local Cloudflare preview (npm run preview).
# Add the same values as .env.local — Wrangler does not read .env.local automatically.
# Do not commit .dev.vars — it may contain secrets.

NEXTJS_ENV=development

# NEXT_PUBLIC_SITE_URL=http://localhost:8787
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# NEXT_PUBLIC_SUPABASE_REDIRECT_URL=http://localhost:8787/auth/callback
